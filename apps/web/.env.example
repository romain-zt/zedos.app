# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# Optional pool tuning (per Node process; one shared pool in dev via globalThis)
DATABASE_POOL_MAX="3"
DATABASE_IDLE_TIMEOUT_SEC="20"

# Test database (docker compose up postgres → postgresql://zedos_test:zedos_test@localhost:5433/zedos_test)
TEST_DATABASE_URL="postgresql://zedos_test:zedos_test@localhost:5433/zedos_test"

# Playwright E2E (optional — defaults match scripts/seed-e2e.ts)
E2E_USER_EMAIL="e2e@zedos.test"
E2E_USER_PASSWORD="E2eTestPassword123!"
E2E_NO_CREDITS_EMAIL="e2e-nocredits@zedos.test"
E2E_NO_CREDITS_PASSWORD="E2eTestPassword123!"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# Set to "true" only for Playwright/CI (deterministic Stripe + AI stubs). Never in production.
# E2E_MODE="true"

# PostHog product analytics (EU Cloud recommended). Tracking is off until keys are set.
# Legal gate B-ANALYTICS-001 before enabling on production users.
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# POSTHOG_API_KEY="phc_..."
# POSTHOG_HOST="https://eu.i.posthog.com"
# NEXT_PUBLIC_POSTHOG_DISABLED="true"
# E2E_MAIN_USER_CREDITS="500"

# PostHog session replay (B-ANALYTICS-001 legal + B-ANALYTICS-002 masking sign-off
# REQUIRED before enabling on production users). Default: false. Even when set to
# "true" replay only starts when PostHog itself is configured (NEXT_PUBLIC_POSTHOG_KEY).
# Masking applies via [data-ph-mask] / .ph-no-capture selectors — see
# docs/observability/posthog.md §6.
# NEXT_PUBLIC_POSTHOG_SESSION_REPLAY_ENABLED="false"

# Auth (better-auth — set on Vercel; Turbo passes these only if listed in turbo.jsonc globalEnv)
BETTER_AUTH_SECRET="min-32-chars-generate-with-openssl-rand-base64-24"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
# Ops (staging/prod): Dashboard → Developers → Webhooks → signing secret
# (handles checkout.session.completed AND customer.subscription.*)
STRIPE_WEBHOOK_SECRET="whsec_..."
# Ops: enable Stripe Tax in Dashboard (Settings → Tax) before automatic_tax on Checkout
# Set to "0" to disable Stripe Tax on Checkout (defaults to enabled when unset)
STRIPE_AUTOMATIC_TAX_ENABLED="1"

# Stripe Builder subscription (FA-payments--builder-subscription-checkout v1).
# Until STRIPE_BUILDER_PRICE_ID is set the subscription checkout endpoint returns
# 503 not_configured. Configure a recurring Price in Stripe Dashboard (Products →
# Builder → Add price → Recurring → monthly), copy the price_... id here.
STRIPE_BUILDER_PRICE_ID="price_..."
# Display-only — keep in sync with the configured Price for the UI/checkout meta.
STRIPE_BUILDER_MONTHLY_EUR="29"
# Display name surfaced in checkout/billing UI. Defaults to "Builder".
BUILDER_PLAN_NAME="Builder"
# Optional: Stripe Customer Portal configuration ID. When unset, Stripe picks the
# default portal configuration for the account.
# STRIPE_PORTAL_CONFIG_ID="bpc_..."

# Team data room (FA-team-data-room--bundle-export-zip v1).
# Maximum bundle size, in bytes. Defaults to 200 MiB. Bundles exceeding this size
# are rejected before streaming so we don't OOM on huge attachments.
DATA_ROOM_MAX_BYTES="209715200"

# Ops hygiene (operator — rotate if ever committed; see docs/state/status.json phase 0)
# BETTER_AUTH_SECRET / NEXTAUTH_SECRET, DATABASE_URL password, ABACUSAI_API_KEY

# Default fetch timeout for callAI (ms).
AI_REQUEST_TIMEOUT_MS="120000"
# User-story AI: outline pass + one HTTP call per story (see user-story-draft.ts).
AI_USER_STORY_DRAFT_OUTLINE_TIMEOUT_MS="60000"
AI_USER_STORY_DRAFT_SINGLE_TIMEOUT_MS="90000"
AI_USER_STORY_DRAFT_MAX_STORIES="12"
ABACUSAI_API_KEY="your-abacusai-key"

# Transactional emails (Resend)
RESEND_API_KEY="re_..."
MAIL_FROM="Zedos <noreply@zedos.app>"

# Credit configuration (all optional — defaults shown)
STARTER_CREDITS="20"
CREDIT_COST_CLARIFICATION="1"
CREDIT_COST_DECISION="3"
CREDIT_COST_MINI_FORM="5"
CREDIT_COST_PRD_GENERATION="10"
CREDIT_COST_PRD_CHALLENGE="15"
CREDIT_COST_FEATURE_SPLIT="5"
CREDIT_COST_USER_STORIES="5"
CREDIT_COST_TASK_SPLIT="5"
GRACE_CREDIT_CEILING="20"

# Credit packs (operator config — defaults shown)
PACK_100_PRICE_EUR="9"
PACK_200_PRICE_EUR="17"
PACK_1000_PRICE_EUR="69"

# GitHub PRD-drift integration (FA-prd-drift-github v1 — minimal scaffold).
# Until these are set the OAuth surface returns 503 not_configured and webhooks
# fail signature verification. See docs/product/feature-areas/prd-drift-github.md
# and the three v1 plans under docs/execution/plans/prd-drift-github--*.
GITHUB_APP_CLIENT_ID="Iv1.xxxxxxxxxxxxxxxx"
GITHUB_APP_CLIENT_SECRET="github_pat_secret"
# Webhook secret used to HMAC-verify GitHub deliveries (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"
# Optional canonical app URL used to build OAuth redirect URIs in v1 stubs.
GITHUB_OAUTH_REDIRECT_BASE_URL="http://localhost:3000"
# Weekly drift digest cron entrypoint (`/api/jobs/drift-weekly-digest`). Default
# OFF per scope slice prd-drift-github--evaluate-and-weekly-digest v1: the route
# returns 503 unless the flag is "true" *and* the request carries the secret.
DRIFT_WEEKLY_DIGEST_ENABLED="false"
CRON_SHARED_SECRET="generate-with-openssl-rand-base64-32"

# Linear integration (FA-integrations-linear v1 — minimal scaffold).
# v1 uses a personal Linear API key per owner-project rather than OAuth — that's
# the minimum surface to exercise push + webhook ingest. When LINEAR_API_KEY is
# absent, the push endpoint returns 503 not_configured.
LINEAR_API_KEY="lin_api_xxxxxxxxxxxxxxxx"
# Webhook secret used to HMAC-verify Linear deliveries (Linear-Signature).
LINEAR_WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"

## 10. Testing contracts

```typescript
import { CreateProjectRequestSchema, ProjectDTOSchema } from '@contracts/project';

it('validates valid create request', () => {
  const data = { name: 'My Project', description: 'About my project' };
  const result = CreateProjectRequestSchema.safeParse(data);
  expect(result.success).toBe(true);
});

it('rejects missing name', () => {
  const data = { description: 'About my project' };
  const result = CreateProjectRequestSchema.safeParse(data);
  expect(result.success).toBe(false);
});
```


## 6. Forbidden patterns

### ❌ No raw SDK calls outside infrastructure

```typescript
// WRONG: Stripe call in application logic
import Stripe from 'stripe';
export async function purchaseCredits(packId: string) {
  const stripe = new Stripe(process.env.STRIPE_SECRET_KEY);
  const session = await stripe.checkout.sessions.create(...);
}

// RIGHT: call via injected infrastructure port
export async function purchaseCredits(
  packId: string,
  paymentService: PaymentService
): Promise<Result<{ sessionUrl: string }>> {
  const result = await paymentService.createCheckoutSession(packId);
  if (result.isErr()) return result;
  return ok({ sessionUrl: result.unwrap().url });
}
```

### ❌ No Prisma types leaking

```typescript
// WRONG: Prisma.User in application
import { Prisma } from '@prisma/client';
export async function getUser(id: string): Promise<Prisma.User> { ... }

// RIGHT: Domain entity + mapper
export async function getUser(id: string): Promise<User> { ... }
```

### ❌ No business logic in routes

```typescript
// WRONG: Credit checking in API route
export async function POST(req: Request) {
  const credits = await prisma.user.findUnique(...);
  if (credits.creditBalance < 10) throw new Error("Insufficient credits");
}

// RIGHT: call use-case from application layer
export async function POST(req: Request) {
  const result = await checkCreditsAndDeductUseCase(user.id, 10);
  if (result.isErr()) return toHttpResponse(result.error);
  return Response.json({ success: true });
}
```


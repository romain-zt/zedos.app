# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# Optional pool tuning (per Node process; one shared pool in dev via globalThis)
DATABASE_POOL_MAX="3"
DATABASE_IDLE_TIMEOUT_SEC="20"

# Optional — integration tests in apps/web use TEST_DATABASE_URL or DATABASE_URL
# TEST_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
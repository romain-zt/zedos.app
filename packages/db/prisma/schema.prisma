generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  passwordHash          String?  @map("password_hash")
  name                  String
  creditBalance         Int      @default(0) @map("credit_balance")
  starterCreditsGranted Boolean  @default(false) @map("starter_credits_granted")
  graceUsed             Boolean  @default(false) @map("grace_used")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  projects             Project[]
  creditTransactions   CreditTransaction[]
  purchases            Purchase[]
  autoReloadPreference AutoReloadPreference?
  milestoneFeedback    MilestoneFeedback[]

  @@map("users")
}

model Project {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  name                  String
  description           String?  @db.Text
  phase                 String   @default("intake")
  architectureStartedAt DateTime? @map("architecture_started_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  prdVersions       PrdVersion[]
  questionHistory   QuestionHistory[]
  milestoneFeedback MilestoneFeedback[]
  adrs              Adr[]

  @@index([userId])
  @@map("projects")
}

model PrdVersion {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  versionNumber Int      @map("version_number")
  content       Json?
  status        String   @default("draft")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionHistory   QuestionHistory[]
  milestoneFeedback MilestoneFeedback[]
  shareLinks        ShareLink[]

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@map("prd_versions")
}

model QuestionHistory {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  prdVersionId       String?  @map("prd_version_id")
  structuredQuestion String   @map("structured_question") @db.Text
  availableOptions   Json?    @map("available_options")
  founderAnswer      String?  @map("founder_answer") @db.Text
  optionalComment    String?  @map("optional_comment") @db.Text
  aiInterpretation   String?  @map("ai_interpretation") @db.Text
  prdImpact          String?  @map("prd_impact") @db.Text
  questionType       String   @default("clarification") @map("question_type")
  createdAt          DateTime @default(now()) @map("created_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prdVersion PrdVersion? @relation(fields: [prdVersionId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([prdVersionId])
  @@map("question_history")
}

model CreditTransaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String
  amount        Int
  balanceAfter  Int      @map("balance_after")
  operationType String?  @map("operation_type")
  metadata      Json?
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@unique([userId, correlationId], name: "credit_transactions_user_correlation_idx")
  @@map("credit_transactions")
}

model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique @map("event_id")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_webhook_events")
}

model Purchase {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  packSize              Int      @map("pack_size")
  amountEur             Int      @map("amount_eur")
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  stripeSessionId       String?  @map("stripe_session_id")
  status                String   @default("pending")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSessionId])
  @@map("purchases")
}

model AutoReloadPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  enabled               Boolean  @default(false)
  packSize              Int      @default(100) @map("pack_size")
  thresholdCredits      Int      @default(5) @map("threshold_credits")
  stripePaymentMethodId String?  @map("stripe_payment_method_id")
  stripeCustomerId      String?  @map("stripe_customer_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auto_reload_preferences")
}

model MilestoneFeedback {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  projectId     String   @map("project_id")
  prdVersionId  String?  @map("prd_version_id")
  milestoneType String   @map("milestone_type")
  ratingType    String   @default("stars") @map("rating_type")
  ratingValue   Int?     @map("rating_value")
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prdVersion PrdVersion? @relation(fields: [prdVersionId], references: [id], onDelete: SetNull)

  @@index([userId, milestoneType])
  @@map("milestone_feedback")
}

model ShareLink {
  id           String    @id @default(cuid())
  prdVersionId String    @map("prd_version_id")
  token        String    @unique
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  disabledAt   DateTime? @map("disabled_at")

  prdVersion PrdVersion @relation(fields: [prdVersionId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("share_links")
}

model Adr {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  adrNumber   Int      @map("adr_number")
  title       String
  content     String   @db.Text
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, adrNumber])
  @@index([projectId])
  @@map("adrs")
}

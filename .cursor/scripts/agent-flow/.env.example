# ── Required ──────────────────────────────────────────────────────────────

# Cursor API key (https://cursor.com/settings → API keys). Used by the SDK
# to run local agents. NEVER commit the real value.
CURSOR_API_KEY=

# Bearer token protecting the HTTP API and WebSocket. Pick any long random
# string; the UI will prompt for it on first load.
AUTH_TOKEN=change-me-to-a-long-random-string

# Postgres connection string.
# - docker compose: leave as-is (the app service points at the postgres service)
# - native: point at your own Postgres, e.g. postgresql://user:pass@localhost:5432/agentflow
DATABASE_URL=postgresql://agentflow:agentflow@postgres:5432/agentflow

# Absolute path (on the host) of the project the agents work on.
# docker compose bind-mounts it to /workspace inside the container.
# Running natively, agents use this directory directly as their cwd.
TARGET_PROJECT_DIR=/path/to/your/project

# ── Optional ──────────────────────────────────────────────────────────────

# HTTP port for the UI / API (default 3900).
PORT=3900

# Model tier ladder. Each accepts a valid Cursor SDK local model id
# (see `Cursor.models.list()`), e.g. claude-fable-5, claude-opus-4-6,
# claude-sonnet-4-6, composer-2.5.
# VISION       — session kickoff framing + final review (session boundaries only)
MODEL_VISION=claude-fable-5
# TOP_MANAGEMENT — synthesis on phase changes / every N turns, escalation target
MODEL_TOP_MGMT=claude-opus-4-6
# MANAGEMENT   — per-turn routing (strict JSON), Skeptic
MODEL_MANAGEMENT=claude-sonnet-4-6
# EXECUTION    — specialists, Spark, code bricks (one brick per run)
MODEL_EXECUTION=composer-2.5

# Run a TOP_MANAGEMENT synthesis every N orchestrator turns (besides phase
# transitions). Default 8.
SYNTHESIS_EVERY_N_TURNS=8

# How many recent messages each agent receives verbatim; older messages get
# folded into a rolling summary. Default 30.
CONTEXT_WINDOW_MESSAGES=30

# Max agent turns before the loop pauses and asks the human. Default 24.
MAX_AGENT_TURNS_PER_CYCLE=24

{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "check:migration-dupes": "node ./scripts/check-duplicate-migrations.mjs",
    "generate": "pnpm run check:migration-dupes && drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "pnpm run check:migration-dupes && node ./scripts/run-migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "node --test scripts/database-url.test.mjs scripts/run-migrate.test.mjs src/migrations/better-auth-migration.node-test.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "20.6.2",
    "dotenv": "16.5.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "5.2.2"
  }
}

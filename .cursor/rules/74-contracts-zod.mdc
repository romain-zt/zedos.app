## 5. Usage across layers

### API Routes

```typescript
export async function POST(req: Request) {
  const parsed = CreateProjectRequestSchema.safeParse(await req.json());
  if (!parsed.success) {
    return Response.json(
      { error: 'Invalid input', details: parsed.error.flatten() },
      { status: 400 }
    );
  }

  const result = await createProjectUseCase(parsed.data, userId);
  if (result.isErr()) {
    return Response.json({ error: result.error.message }, { status: result.error.statusCode });
  }

  const dtoValidation = ProjectDTOSchema.safeParse(result.unwrap());
  if (!dtoValidation.success) {
    return Response.json({ error: 'Internal error' }, { status: 500 });
  }

  return Response.json(dtoValidation.data);
}
```

### React Components

```typescript
import { ProjectDTOSchema } from '@contracts/project';
type ProjectDTO = z.infer<typeof ProjectDTOSchema>;

export function ProjectCard({ project }: { project: ProjectDTO }) {
  return <div>{project.name}</div>;
}
```

### Application Layer

```typescript
import { CreateProjectRequest } from '@contracts/project';

export async function createProjectUseCase(
  input: CreateProjectRequest,  // Already validated
  userId: string,
  projectRepository: ProjectRepository
): Promise<Result<Project>> {
  // ...
}
```

### Infrastructure Adapters

```typescript
import { ClarifyResponseSchema } from '@contracts/ai';

export class AbacusAIClient {
  async clarify(request: ClarifyRequest): Promise<Result<ClarifyResponse>> {
    try {
      const raw = await fetch('...').then((r) => r.json());
      const validation = ClarifyResponseSchema.safeParse(raw);
      if (!validation.success) {
        return err(new ExternalServiceError('ai', `Response validation failed`));
      }
      return ok(validation.data);
    } catch (e) {
      return err(new ExternalServiceError('ai', e.message));
    }
  }
}
```


## 4. Schema examples

### Request schema

```typescript
// src/contracts/project/create.ts
import { z } from 'zod';
import { IdSchema } from '../shared/common';

export const CreateProjectRequestSchema = z.object({
  name: z.string().min(1).max(255),
  description: z.string().max(2000).optional(),
});

export type CreateProjectRequest = z.infer<typeof CreateProjectRequestSchema>;
```

### DTO schema

```typescript
export const ProjectDTOSchema = z.object({
  id: IdSchema,
  name: z.string(),
  description: z.string().nullable(),
  phase: z.enum(['intake', 'architecture']),
  createdAt: z.date(),
  updatedAt: z.date(),
});

export type ProjectDTO = z.infer<typeof ProjectDTOSchema>;
```

### AI response schema

```typescript
// src/contracts/ai/clarification.ts
export const ClarifyResponseSchema = z.object({
  reasoning: z.string(),
  question: AIQuestionSchema,
  prdUpdates: z.record(z.string(), z.any()),
});

export type ClarifyResponse = z.infer<typeof ClarifyResponseSchema>;
```

### Vendor response schema

```typescript
// src/contracts/payments/checkout.ts
export const CheckoutSessionSchema = z.object({
  id: z.string(),
  url: z.string().url(),
  payment_status: z.enum(['unpaid', 'paid', 'no_payment_required']),
  metadata: z.record(z.string()),
  created: z.number(),
});

export type CheckoutSession = z.infer<typeof CheckoutSessionSchema>;
```

